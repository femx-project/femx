{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "FEMX_ENABLE_ENZYME": "OFF",
        "FEMX_ENABLE_HDF5": "ON",
        "FEMX_ENABLE_OPENMP": "ON",
        "FEMX_BUILD_APPS": "ON",
        "FEMX_BUILD_EXAMPLES": "ON",
        "FEMX_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "resolve-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "FEMX_ENABLE_RESOLVE": "ON",
        "FEMX_ENABLE_PETSC": "OFF",
        "FEMX_REQUIRE_RESOLVE": "ON"
      }
    },
    {
      "name": "resolve",
      "displayName": "ReSolve CPU",
      "description": "Build apps/tests with a CPU-only ReSolve package.",
      "inherits": "resolve-base",
      "binaryDir": "${sourceDir}/build/resolve",
      "cacheVariables": {
        "FEMX_RESOLVE_BACKEND": "CPU",
        "RESOLVE_USE_CUDA": "OFF"
      }
    },
    {
      "name": "resolve-cuda",
      "displayName": "ReSolve CUDA",
      "description": "Build apps/tests with the CUDA-enabled ReSolve backend.",
      "inherits": "resolve-base",
      "binaryDir": "${sourceDir}/build/resolve-cuda",
      "cacheVariables": {
        "FEMX_RESOLVE_BACKEND": "CUDA",
        "RESOLVE_USE_CUDA": "ON",
        "CMAKE_CUDA_ARCHITECTURES": "60"
      }
    },
    {
      "name": "petsc",
      "displayName": "PETSc",
      "description": "Build apps/tests with PETSc enabled and ReSolve disabled.",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/petsc",
      "cacheVariables": {
        "FEMX_ENABLE_RESOLVE": "OFF",
        "FEMX_ENABLE_PETSC": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "resolve",
      "configurePreset": "resolve"
    },
    {
      "name": "resolve-cuda",
      "configurePreset": "resolve-cuda"
    },
    {
      "name": "petsc",
      "configurePreset": "petsc"
    }
  ],
  "testPresets": [
    {
      "name": "resolve",
      "configurePreset": "resolve",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "resolve-cuda",
      "configurePreset": "resolve-cuda",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "petsc",
      "configurePreset": "petsc",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
