@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")

if(@FEMX_ENABLE_OPENMP@)
  find_dependency(OpenMP)
endif()

if(@FEMX_HAS_RESOLVE@)
  find_dependency(ReSolve 0.99.2 EXACT)
endif()

if(@FEMX_HAS_HDF5@)
  find_dependency(HDF5 COMPONENTS C)
endif()

if(@FEMX_HDF5_USES_MPI@)
  find_dependency(MPI COMPONENTS CXX)
endif()

if(@FEMX_HAS_PETSC@)
  find_dependency(MPI COMPONENTS CXX)
  find_dependency(PkgConfig)
  if(NOT TARGET PkgConfig::PETSC)
    pkg_check_modules(PETSC QUIET IMPORTED_TARGET PETSc)
    if(NOT PETSC_FOUND)
      pkg_check_modules(PETSC REQUIRED IMPORTED_TARGET petsc)
    endif()
  endif()
endif()

if(@FEMX_HAS_ENZYME@)
  find_dependency(Enzyme)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/femxTargets.cmake")

if(TARGET femx::model_ns AND NOT TARGET femx::model::ns)
  add_library(femx::model::ns ALIAS femx::model_ns)
endif()
